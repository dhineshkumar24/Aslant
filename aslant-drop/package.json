{
  "name": "aslant-drop",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "cap:sync": "npm run build && npx cap sync",
    "cap:sync:ios": "npm run build && npx cap sync ios",
    "cap:sync:android": "npm run build && npx cap sync android",
    "cap:copy": "npx cap copy",
    "cap:ios": "npx cap open ios",
    "cap:android": "npx cap open android",
    "assets:generate": "node scripts/generate-brand-assets.mjs && npx capacitor-assets generate --iconBackgroundColor '#0a0a0f' --splashBackgroundColor '#0a0a0f'",
    "android:bundle": "npm run cap:sync:android && cd android && ./gradlew bundleRelease"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "sharp": "^0.35.2",
    "vite": "^8.0.12"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/cli": "^8.4.1",
    "@capacitor/core": "^8.4.1",
    "@capacitor/ios": "^8.4.1",
    "phaser": "^4.2.0"
  }
}
